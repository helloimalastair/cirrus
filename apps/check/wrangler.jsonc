{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "pdscheck",
	"compatibility_date": "2026-05-24",
	"assets": {
		"directory": "./dist",
		"not_found_handling": "single-page-application"
	},
	"routes": [
		{
			"pattern": "check.cirrus.earth",
			"custom_domain": true
		}
	],
	"observability": {
		"enabled": true
	}
}
